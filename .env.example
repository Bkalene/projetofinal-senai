GithubKey=SUA_CHAVE_GITHUB_AQUI

GeminiKey=SUA_CHAVE_GEMINI_AQUI

# O URL da API não é o do painel (dashboard), é a URL de conexão do projeto:
VITE_SUPABASE_URL=URL_DO_SEU_PROJETO_SUPABASE
SUPABASE_URL=URL_DO_SEU_PROJETO_SUPABASE

# Essa é a chave secreta (SERVICE_ROLE_KEY) que peguei do seu print:
SUPABASE_SERVICE_ROLE_KEY=SUA_CHAVE_PUBLICA_OU_SECRETA_SUPABASE

# COLE A CHAVE PUBLICÁVEL AQUI (copie clicando no ícone do lado direito dela no print):
VITE_SUPABASE_ANON_KEY=SUA_CHAVE_PUBLICA_SUPABASE
SUPABASE_ANON_KEY=SUA_CHAVE_PUBLICA_SUPABASE
